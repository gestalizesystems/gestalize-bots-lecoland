# Chave da API do Google Gemini (GRATUITA): https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Modelo a usar (padrão: gemini-2.5-flash — gratuito e funcionando bem).
# Obs.: o gemini-2.0-flash teve a cota gratuita zerada; prefira o 2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# Porta do painel de administração (acesse em http://localhost:4500).
ADMIN_PORT=4500

# Chave GRATUITA do OpenRouteService para calcular distância pelo endereço do cliente.
# Crie em: https://openrouteservice.org/dev/#/signup (sem cartão de crédito).
# Se ficar vazio, o bot ainda calcula por km informado, mas não geolocaliza endereço.
ORS_API_KEY=
